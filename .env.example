# Copy this file to .env and fill in real values. Never commit .env.

# Neon Postgres connection string (server-side only)
DATABASE_URL=

# Google Gemini API key (server-side only)
GEMINI_API_KEY=

# Lykdat clothing-detection API key (server-side only)
LYKDAT_API_KEY=

# Vercel Blob read-write token for image storage (server-side only)
BLOB_READ_WRITE_TOKEN=

# Sentry error tracking DSN (client-side, optional — error reporting is off without it)
VITE_SENTRY_DSN=

# Kornia warp backend URL (client-side, optional, local dev only)
# VITE_WARP_API_URL=http://localhost:8000
